{
  "name": "@garcon/server-agent-common",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./shared/*": "./src/shared/*.ts",
    "./lib/*": "./src/lib/*.ts",
    "./chats/*": "./src/chats/*.ts",
    "./auth/*": "./src/auth/*.ts",
    "./direct/*": "./src/direct/*.ts",
    "./search/*": "./src/search/*.ts",
    "./catalog/*": "./src/catalog/*.ts",
    "./environment/*": "./src/environment/*.ts",
    "./execution/*": "./src/execution/*.ts",
    "./forking/*": "./src/forking/*.ts",
    "./lifecycle/*": "./src/lifecycle/*.ts",
    "./logging/*": "./src/logging/*.ts",
    "./migration/*": "./src/migration/*.ts",
    "./native-session/*": "./src/native-session/*.ts",
    "./settings/*": "./src/settings/*.ts"
  },
  "scripts": {
    "typecheck": "bunx tsc -p tsconfig.json"
  },
  "dependencies": {
    "@garcon/common": "workspace:*",
    "@garcon/server-agent-interface": "workspace:*"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "typescript": "^6.0.3"
  }
