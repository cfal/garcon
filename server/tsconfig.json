{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "rewriteRelativeImportExtensions": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "types": ["@types/bun"]
  },
  "include": [
    "**/*.ts",
    "../common/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "**/__tests__/**"
  ]
}
